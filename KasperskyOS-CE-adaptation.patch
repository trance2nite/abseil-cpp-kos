diff --git a/absl/base/internal/unscaledcycleclock.h b/absl/base/internal/unscaledcycleclock.h
index bfd98873..dffe4780 100644
--- a/absl/base/internal/unscaledcycleclock.h
+++ b/absl/base/internal/unscaledcycleclock.h
@@ -98,7 +98,14 @@ inline int64_t UnscaledCycleClock::Now() {
 // virtual timer properly.
 inline int64_t UnscaledCycleClock::Now() {
   int64_t virtual_timer_value;
+
+  #ifdef __KOS__
+  // In KasperskyOS, only the Counter-timer Physical Count register (CNTPCT_EL0) is readable from EL0.
+  asm volatile("isb");
+  asm volatile("mrs %0, cntpct_el0" : "=r"(virtual_timer_value));
+  #else
   asm volatile("mrs %0, cntvct_el0" : "=r"(virtual_timer_value));
+  #endif
   return virtual_timer_value;
 }
 
