diff --git a/absl/time/internal/cctz/src/time_zone_info_embedded.cc b/absl/time/internal/cctz/src/time_zone_info_embedded.cc
new file mode 100644
index 00000000..48a090b8
--- /dev/null
+++ b/absl/time/internal/cctz/src/time_zone_info_embedded.cc
@@ -0,0 +1,81 @@
+#ifdef __KOS__
+// Embedding Time Zones for KasperskyOS only.
+
+#include "absl/base/config.h"
+#include "absl/time/internal/cctz/include/cctz/zone_info_source.h"
+
+namespace cctz = absl::time_internal::cctz;
+
+namespace absl {
+ABSL_NAMESPACE_BEGIN
+namespace time_internal {
+namespace cctz_extension {
+namespace {
+
+const struct ZoneInfo {
+  const std::string name;
+  const std::vector<char> data;
+} kZoneInfo[] = {
+
+// The data was generated using command `od -v -An -tx1 zoneinfo-file`.
+// See "absl/time/internal/cctz/testdata/README.zoneinfo" to update the data
+// and "absl/time/internal/cctz/testdata/gen_embedded_tz.sh" to generate
+// initializers.
+#include "absl/time/internal/cctz/src/time_zone_info_data.inc"
+};
+
+class EmbeddedZoneInfoSource : public cctz::ZoneInfoSource {
+ public:
+  EmbeddedZoneInfoSource(const char* data, std::size_t size)
+      : data_(data), end_(data + size) {}
+
+  std::size_t Read(void* ptr, std::size_t size) override {
+    const std::size_t len =
+        std::min<std::size_t>(size, static_cast<size_t>(end_ - data_));
+    memcpy(ptr, data_, len);
+    data_ += len;
+    return len;
+  }
+
+  int Skip(std::size_t offset) override {
+    data_ += std::min<std::size_t>(offset, static_cast<size_t>(end_ - data_));
+    return 0;
+  }
+
+ private:
+  const char* data_;
+  const char* const end_;
+};
+
+std::unique_ptr<cctz::ZoneInfoSource> EmbeddedFactory(
+    const std::string& name,
+    const std::function<std::unique_ptr<cctz::ZoneInfoSource>(
+        const std::string& name)>& fallback_factory) {
+  // Search in embedded Time Zones.
+  for (const ZoneInfo& zoneinfo : kZoneInfo) {
+    if (name == zoneinfo.name) {
+      if (zoneinfo.data.size() == 0) {
+        // Invalid embedded TZ data for that name - fallback.
+        break;
+      }
+      return std::unique_ptr<cctz::ZoneInfoSource>(
+          new EmbeddedZoneInfoSource(zoneinfo.data.data(), zoneinfo.data.size()));
+    }
+  }
+
+  // Fallback to default.
+  if (auto zip = fallback_factory(name)) return zip;
+  return nullptr;
+}
+
+}  // namespace
+
+// Override the weak symbol.
+ZoneInfoSourceFactory zone_info_source_factory = EmbeddedFactory;
+
+}  // namespace cctz_extension
+}  // namespace time_internal
+ABSL_NAMESPACE_END
+}  // namespace absl
+
+#endif  // __KOS__
diff --git a/absl/time/internal/cctz/testdata/gen_embedded_tz.sh b/absl/time/internal/cctz/testdata/gen_embedded_tz.sh
new file mode 100755
index 00000000..cae7b5b9
--- /dev/null
+++ b/absl/time/internal/cctz/testdata/gen_embedded_tz.sh
@@ -0,0 +1,33 @@
+#!/usr/bin/env bash
+#
+
+set -e
+
+#
+# zoneinfo conversion utility script to make time zone info initializer for
+# embedded Zone Info Source.
+#
+# Run
+# $ gen_embedded_tz.sh > time_zone_info_data.inc
+#
+
+shopt -s globstar nullglob dotglob extglob
+
+pushd $(dirname "$(realpath "${0}")")/zoneinfo > /dev/null
+
+for f in **/*([^.]); do
+    if [ -f "${f}" ]; then
+        echo "{"
+        echo "  .name = \"${f}\","
+        echo "  .data = {"
+        od -v -An -tx1 "${f}" | \
+        sed 's/\b\S\S\b/0x&,/g' | \
+        sed 's/^/   /g'
+        echo "  }"
+        echo "},"
+    fi
+done
+
+popd  > /dev/null
+
+shopt -u globstar nullglob dotglob extglob
